{
    "compilerOptions": {
      "target": "ES2022",
      "module": "Node16",
      "moduleResolution": "Node16",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "noEmitOnError": false,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "outDir": "./build",
      "rootDir": "."
    },
    "exclude": ["node_modules"]
  }